# Environment profile.
APP_ENV=development
APP_LOG_LEVEL=INFO

# HTTP server.
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=20s

# Persistence.
DATABASE_URL=postgres://controlplane:controlplane@localhost:5432/controlplane?sslmode=disable
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MIN_IDLE_CONNS=2
DATABASE_MAX_CONN_LIFETIME=30m
DATABASE_MAX_CONN_IDLE_TIME=5m

# Worker runtime.
WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=5
JOB_LEASE_DURATION=30s
JOB_MAX_ATTEMPTS=5

# Auth.
# Supported modes: hmac, oidc
AUTH_MODE=hmac
AUTH_AUDIENCE=golden-path-control-plane
AUTH_ISSUER=golden-path-local
AUTH_HMAC_SECRET=replace-me-with-a-32-character-minimum-secret
AUTH_OIDC_ISSUER_URL=
AUTH_OIDC_JWKS_URL=

# Observability.
OTEL_SERVICE_NAME=golden-path-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_NAMESPACE=goldenpath
